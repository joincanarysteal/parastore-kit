  # .env.example — copy this file to .env and fill in your API keys.
  # DO NOT commit real keys.
  # cp .env.example .env

  # LLM provider keys. The active provider/model is hardcoded in
  # backend/src/store_emulator/application/config.py (default:
  # gemini/gemini-3.1-pro-preview via LiteLLM). Setting OPENAI_API_KEY or
  # ANTHROPIC_API_KEY alone has NO effect — to switch providers, edit
  # LLMConfig.model in config.py to the matching LiteLLM model string AND
  # fill in the corresponding key below.
  GEMINI_API_KEY=
  OPENAI_API_KEY=
  ANTHROPIC_API_KEY=

  # Optional. Ceiling for the per-day persona generation cap (multiples of 10).
  # Used only when a request supplies max_persona_count_per_day — the per-day
  # slice is clamped to this value. Default: 100.
  PERSONA_DAILY_CAP=100